{
  "name": "tbl-chart-engine",
  "version": "0.0.0",
  "description": "Budget Lab chart engine — config-driven, Style-Guide-themed interactive charts (Observable Plot + D3).",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "tbl-chart": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/engine/index.js",
    "./spec": "./dist/spec/index.js",
    "./data": "./dist/data/index.js"
  },
  "scripts": {
    "sync-theme": "node scripts/sync-theme.mjs",
    "build": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "ajv": "^8.17.0"
  }
}
