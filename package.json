{
  "name": "budget-lab-chart-engine",
  "version": "0.1.3",
  "description": "Budget Lab chart engine — config-driven, Style-Guide-themed interactive charts (Observable Plot + D3).",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "tbl-chart": "./dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/engine/index.js",
    "./spec": "./dist/spec/index.js",
    "./data": "./dist/data/index.js"
  },
  "scripts": {
    "gen-assets": "node scripts/gen-assets.mjs",
    "sync-theme": "node scripts/sync-theme.mjs",
    "build": "node scripts/build.mjs",
    "prepare": "node scripts/build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "snapshot:selftest": "node scripts/snapshot-selftest.mjs"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "playwright": "^1.0.0",
    "pngjs": "^7.0.0",
    "pixelmatch": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "playwright": { "optional": true },
    "pngjs": { "optional": true },
    "pixelmatch": { "optional": true }
  }
}